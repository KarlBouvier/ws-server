NEXTAUTH_SECRET="same-as-next-app"
DATABASE_LOCAL_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
WS_PORT=3001
# Optional: require header x-pdf-api-key on POST /api/pdf (must match Next.js PDF_API_KEY)
PDF_API_KEY=""

# Puppeteer / Chromium
# So Puppeteer can find the browser reliably on fresh machines:
# 1) run: npx puppeteer browsers install chrome
# 2) keep puppeteer cache under ws-server
PUPPETEER_CACHE_DIR="./.puppeteer-cache"

# Optional (recommended if you deploy to a machine with a fixed cache):
# PUPPETEER_EXECUTABLE_PATH="/absolute/path/to/Google Chrome for Testing"
